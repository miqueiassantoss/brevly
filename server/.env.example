# Porta da API — padrão: 3333 caso omitido
PORT=3333

# String de conexão com o PostgreSQL.
# Ao utilizar o Docker Compose, este valor é definido automaticamente; o valor
# abaixo corresponde às variáveis POSTGRES_* ao final deste arquivo.
DATABASE_URL="postgresql://postgres:docker@127.0.0.1:5432/brevly"

# --- Cloudflare R2 (necessário para a exportação de CSV) ---
# Crie um bucket gratuito em https://dash.cloudflare.com → R2 e gere um token
# de API com permissão de "Object Read & Write" para o bucket criado.
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_KEY_ID=""
CLOUDFLARE_SECRET_ACCESS_KEY=""
CLOUDFLARE_BUCKET=""

# URL pública do bucket — a aplicação utiliza URLs pré-assinadas, portanto o
# bucket não precisa ser público. Deixe em branco a menos que deseje acesso público.
CLOUDFLARE_PUBLIC_URL=""

# --- Configuração do Postgres (utilizada pelo docker-compose.yml) ---
# Deve corresponder às credenciais definidas na DATABASE_URL acima.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=docker
POSTGRES_DB=brevly

# --- CORS ---
# Origem permitida para acessar a API. Deixe em branco para permitir todas as origens.
FRONTEND_URL=http://localhost:5173